{
  "context": {
    "fileName": [
      "AGENTS.md"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "patina-schema-loader",
            "type": "command",
            "command": "node $GEMINI_PROJECT_DIR/scripts/extract_schema.cjs"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "always",
        "hooks": [
          {
            "name": "patina-git-status",
            "type": "command",
            "command": "git status --short >&2; echo '{}'"
          },
          {
            "name": "patina-type-check",
            "type": "command",
            "command": "node scripts/gemini_hook.js type-check"
          },
          {
            "name": "patina-build-check",
            "type": "command",
            "command": "node scripts/gemini_hook.js build"
          },
          {
            "name": "patina-lint-check",
            "type": "command",
            "command": "node scripts/gemini_hook.js lint"
          }
        ]
      }
    ]
  }
}
