{
  "name": "patina",
  "version": "1.2.0",
  "description": "Privacy-first desktop application for historical coin collectors",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main-tsc\" \"npm run dev:electron\"",
    "dev:fresh": "npm run build && npm run dev",
    "dev:renderer": "vite",
    "dev:main-tsc": "tsc -p tsconfig.main.json -w --incremental",
    "dev:electron": "wait-on http://localhost:3000 && VITE_DEV_SERVER_URL=http://localhost:3000 electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "db:seed": "tsc scripts/seed_data.ts --module commonjs --target es2020 --esModuleInterop && electron scripts/seed_data.js && rm scripts/seed_data.js",
    "dist:win": "electron-builder --win --publish never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.patina.collector",
    "productName": "Patina",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/fonts/",
        "to": "fonts/",
        "filter": [
          "**/*.ttf"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Patina"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "i18next": "^25.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "multer": "^2.1.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
